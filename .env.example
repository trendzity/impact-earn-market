# Copy to `.env.local` for local development (never commit `.env.local`).

# --- Required for staging/production builds (Vercel, CI) ---
# Backend API base URL including the `/api` path suffix.
# VITE_API_URL=https://api.yourdomain.com/api

# --- Local development (vite dev) ---
# Optional: override the default http://localhost:5000/api when VITE_API_URL is unset.
# VITE_DEV_API_URL=http://localhost:5000/api

# Or set an explicit local backend:
# VITE_API_URL=http://localhost:5000/api

# --- Escape hatch (NOT recommended) ---
# Allows known production API hosts during dev/staging. Use only for emergencies.
# VITE_ALLOW_PRODUCTION_API=true
